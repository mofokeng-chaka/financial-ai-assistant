<mxfile host="app.diagrams.net">
  <diagram id="financial-ai" name="Architecture">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Client -->
        <mxCell id="user" value="" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.user;pointerEvents=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="60" height="60" as="geometry" />
        </mxCell>
        <mxCell id="user_label" value="Client Application" style="text;html=0;align=center;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
