        <mxCell id="a5" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#DD344C;dashed=1;fontSize=10;fontColor=#DD344C;" edge="1" source="primary" target="fallback" parent="1">
